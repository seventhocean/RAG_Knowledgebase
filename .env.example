ARK_API_KEY= # Ark 平台 API 密钥
MODEL= # 主模型，如 deepseek/deepseek-v3.2-251201
GRADE_MODEL= # 评估模型，用于文档相关性打分，建议与 MODEL 保持一致
FAST_MODEL= # 快速模型，用于简单任务
BASE_URL= # LLM API 基础地址，如 https://api.qnaigc.com/v1

# 本地密集向量（langchain_huggingface / sentence-transformers）
EMBEDDING_MODEL= #BAAI/bge-m3
EMBEDDING_DEVICE= #cpu
DENSE_EMBEDDING_DIM= #1024

# ===== Rerank (可选，不配则自动降级) =====
RERANK_MODEL= #jina-reranker-v3
RERANK_BINDING_HOST= #https://api.jina.ai/v1/rerank
RERANK_API_KEY= #jina_

# ===== Milvus =====
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530

# BM25 稀疏统计持久化（默认项目根下 data/bm25_state.json）
# BM25_STATE_PATH=